{
  "name": "ecomm",
  "version": "0.0.1",
  "description": "",
  "author": "Taiwo Olapade",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "db:seed": "node dist/db/seeders/seeders.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "mail:dev": "cd maizzle && npm run dev",
    "mail:build": "cd maizzle && npm run build",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migration:generate": "npm run build && npx typeorm-ts-node-commonjs -d ./src/modules/config/typeorm.config.ts migration:generate src/db/migrations/$npm_config_name",
    "migration:revert": "npm run typeorm migration:revert",
    "migrate": "npm run typeorm migration:run",
    "migration:generate-2": "npx typeorm-ts-node-commonjs -d ./src/data-source.ts migration:generate ./src/migrations/default",
    "migration:run": "npx typeorm-ts-node-commonjs -d ./src/data-source.ts migration:run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm -d dist/modules/config/typeorm.config.js"
  },
